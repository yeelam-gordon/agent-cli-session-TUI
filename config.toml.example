# ─── Agent Session TUI — Configuration ───
# Copy this file next to agent-session-tui.exe and edit paths for your system.

# App data directory (archived.json, embeddings_cache.json stored here)
# data_dir = '~/.local/share/agent-session-tui'
poll_interval_ms = 2000
log_max_lines = 500

# ─── Launch Configuration ───
# Each provider can configure how sessions are launched in a terminal.
#
# Option 1: Shortcut (simple)
#   launch_method = "wt"       # "wt" (Windows Terminal tab) | "pwsh" | "cmd"
#   launch_fallback = "cmd"    # fallback if launch_method program not found
#
# Option 2: Custom command (full control)
#   launch_cmd = "wt"                      # any program
#   launch_args = ["-w", "0", "new-tab",   # args with placeholders:
#     "--startingDirectory", "{cwd}",       #   {cwd}     → working directory
#     "cmd", "/k", "{command}"]             #   {command}  → the agent CLI command
#   launch_fallback_cmd = "wt"             # fallback program
#   launch_fallback_args = ["-w", "0", "new-tab",
#     "--startingDirectory", "{cwd}",
#     "cmd", "/k", "{command}"]
#
# Custom launch_cmd/args take priority over launch_method when set.

# ─── Semantic Search ───
# No configuration needed. Build the semantic-plugin crate and drop the DLL
# (semantic_plugin.dll / libsemantic_plugin.so) next to the TUI binary.
# The TUI loads it automatically at startup for embedding-based search.

# ─── Copilot CLI ───
[providers.copilot]
enabled = true
default = true
command = "copilot"
default_args = []
# default_args = ["--agent=memory-assistant"]
# default_args = ["--model", "claude-sonnet-4"]
state_dir = '~/.copilot/session-state'
resume_flag = "--resume"
# startup_dir = 'D:\'
launch_method = "wt"
launch_fallback = "cmd"
# wt_profile = "PowerShell"

# ─── Claude Code ───
[providers.claude]
enabled = true
command = "claude"
default_args = []
# default_args = ["--model", "claude-sonnet-4"]
# default_args = ["--allow-dangerously-skip-permissions"]
state_dir = '~/.claude/projects'
resume_flag = "--resume"
# startup_dir = 'D:\'
launch_method = "wt"
launch_fallback = "cmd"
# wt_profile = "PowerShell"

# ─── Qwen CLI ───
[providers.qwen]
enabled = true
command = "qwen"
default_args = []
# default_args = ["--model", "qwen-max"]
resume_flag = "--resume"
# startup_dir = 'D:\'
launch_method = "wt"
launch_fallback = "cmd"
# wt_profile = "PowerShell"

# ─── Codex CLI ───
[providers.codex]
enabled = true
command = "codex"
default_args = []
# default_args = ["--model", "o4-mini"]
state_dir = '~/.codex/sessions'
resume_flag = "resume"
# startup_dir = 'D:\'
launch_method = "wt"
launch_fallback = "cmd"

# ─── Gemini CLI ───
[providers.gemini]
enabled = true
command = "gemini"
default_args = []
# default_args = ["--model", "gemini-2.5-pro"]
state_dir = '~/.gemini'
resume_flag = "--resume"
# startup_dir = 'D:\'
launch_method = "wt"
launch_fallback = "cmd"
# wt_profile = "PowerShell"

