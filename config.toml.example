# ─── Agent Session TUI — Configuration ───
# Copy this file next to agent-session-tui.exe and edit paths for your system.

# App data directory (archived.json stored here)
# data_dir = '~/.local/share/agent-session-tui'
poll_interval_ms = 2000
log_max_lines = 500

# ─── Copilot CLI ───
[providers.copilot]
enabled = true
default = true
command = "copilot"
default_args = []
state_dir = '~/.copilot/session-state'
resume_flag = "--resume"
# startup_dir = 'D:\'
launch_method = "wt"
# wt_profile = "PowerShell"

# ─── Claude Code ───
[providers.claude]
enabled = true
command = "claude"
default_args = []
state_dir = '~/.claude/projects'
resume_flag = "--resume"
# startup_dir = 'D:\'
launch_method = "wt"
# wt_profile = "PowerShell"

